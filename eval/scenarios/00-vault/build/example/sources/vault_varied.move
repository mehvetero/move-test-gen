#[test_only]
module example::vault_varied {
    use example::vault;
    use sui::coin;
    use sui::sui::SUI;

    // ═══ ONE TEST PER ABORT PATH ═══

    #[test]
    #[expected_failure(abort_code = vault::EZeroAmount)]
    fun abort_deposit_zero() {
        let mut ctx = tx_context::dummy();
        let mut v = vault::create_for_testing(&mut ctx);
        vault::deposit(&mut v, coin::mint_for_testing<SUI>(0, &mut ctx));
        vault::destroy_for_testing(v);
    }

    #[test]
    #[expected_failure(abort_code = vault::EZeroAmount)]
    fun abort_withdraw_zero() {
        let mut ctx = tx_context::dummy();
        let mut v = vault::create_for_testing(&mut ctx);
        vault::deposit(&mut v, coin::mint_for_testing<SUI>(1_000_000_000, &mut ctx));
        let o = vault::withdraw(&mut v, 0, &mut ctx);
        coin::burn_for_testing(o);
        vault::destroy_for_testing(v);
    }

    #[test]
    #[expected_failure(abort_code = vault::EInsufficientShares)]
    fun abort_withdraw_excess() {
        let mut ctx = tx_context::dummy();
        let mut v = vault::create_for_testing(&mut ctx);
        vault::deposit(&mut v, coin::mint_for_testing<SUI>(500_000_000, &mut ctx));
        let o = vault::withdraw(&mut v, 500_000_001, &mut ctx);
        coin::burn_for_testing(o);
        vault::destroy_for_testing(v);
    }

    #[test]
    #[expected_failure(abort_code = vault::EZeroAmount)]
    fun abort_flash_borrow_zero() {
        let mut ctx = tx_context::dummy();
        let mut v = vault::create_for_testing(&mut ctx);
        vault::deposit(&mut v, coin::mint_for_testing<SUI>(1_000_000_000, &mut ctx));
        let (b, r) = vault::flash_borrow(&mut v, 0, &mut ctx);
        vault::flash_repay(&mut v, b, r);
        vault::destroy_for_testing(v);
    }

    #[test]
    #[expected_failure(abort_code = vault::EInsufficientBalance)]
    fun abort_flash_borrow_overdraw() {
        let mut ctx = tx_context::dummy();
        let mut v = vault::create_for_testing(&mut ctx);
        vault::deposit(&mut v, coin::mint_for_testing<SUI>(1_000_000_000, &mut ctx));
        let (b, r) = vault::flash_borrow(&mut v, 1_000_000_001, &mut ctx);
        vault::flash_repay(&mut v, b, r);
