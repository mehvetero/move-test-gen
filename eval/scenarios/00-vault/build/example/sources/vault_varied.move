    }

    #[test]
    #[expected_failure(abort_code = vault::EFlashRepayInsufficient)]
    fun abort_flash_repay_underpay() {
        let mut ctx = tx_context::dummy();
        let mut v = vault::create_for_testing(&mut ctx);
        vault::deposit(&mut v, coin::mint_for_testing<SUI>(10_000_000_000, &mut ctx));
        let (borrowed, receipt) = vault::flash_borrow(&mut v, 5_000_000_000, &mut ctx);
        vault::flash_repay(&mut v, borrowed, receipt);
        vault::destroy_for_testing(v);
    }

    #[test]
    #[expected_failure(abort_code = vault::EFeeTooHigh)]
    fun abort_set_fee_over_cap() {
        let mut ctx = tx_context::dummy();
        let mut v = vault::create_for_testing(&mut ctx);
        let cap = vault::create_admin_cap_for_testing(&mut ctx);
        vault::set_fee(&cap, &mut v, 501);
        vault::destroy_admin_cap_for_testing(cap);
        vault::destroy_for_testing(v);
    }

    // ═══ NUMERIC COMPARISON BOUNDARIES ═══

    #[test]
    fun bound_deposit_one_mist() {
        let mut ctx = tx_context::dummy();
        let mut v = vault::create_for_testing(&mut ctx);
        let s = vault::deposit(&mut v, coin::mint_for_testing<SUI>(1, &mut ctx));
        assert!(s == 1);
        vault::destroy_for_testing(v);
    }

    #[test]
    fun bound_withdraw_exact_total() {
        let mut ctx = tx_context::dummy();
        let mut v = vault::create_for_testing(&mut ctx);
        vault::deposit(&mut v, coin::mint_for_testing<SUI>(10_000, &mut ctx));
        let o = vault::withdraw(&mut v, 10_000, &mut ctx);
        // fee = 10_000 * 30 / 10_000 = 30, net = 9_970
        assert!(coin::value(&o) == 9_970);
        coin::burn_for_testing(o);
        vault::destroy_for_testing(v);
    }

    #[test]
    fun bound_flash_borrow_exact_balance() {
        let mut ctx = tx_context::dummy();
        let mut v = vault::create_for_testing(&mut ctx);
        vault::deposit(&mut v, coin::mint_for_testing<SUI>(2_000_000_000, &mut ctx));
        let (mut b, r) = vault::flash_borrow(&mut v, 2_000_000_000, &mut ctx);
        // fee = 2_000_000_000 * 30 / 10_000 = 6_000_000
        b.join(coin::mint_for_testing<SUI>(6_000_000, &mut ctx));
        vault::flash_repay(&mut v, b, r);
        vault::destroy_for_testing(v);
    }

    #[test]
    fun bound_flash_repay_exact_minimum() {
        let mut ctx = tx_context::dummy();
        let mut v = vault::create_for_testing(&mut ctx);
        vault::deposit(&mut v, coin::mint_for_testing<SUI>(10_000_000_000, &mut ctx));
        let (mut b, r) = vault::flash_borrow(&mut v, 1_000_000_000, &mut ctx);
        // fee = 1_000_000_000 * 30 / 10_000 = 3_000_000
        // exact minimum = amount + fee
        b.join(coin::mint_for_testing<SUI>(3_000_000, &mut ctx));
        vault::flash_repay(&mut v, b, r);
        vault::destroy_for_testing(v);
    }

    #[test]
    fun bound_set_fee_at_cap() {
        let mut ctx = tx_context::dummy();
        let mut v = vault::create_for_testing(&mut ctx);
        let cap = vault::create_admin_cap_for_testing(&mut ctx);
        vault::set_fee(&cap, &mut v, 500);
        vault::destroy_admin_cap_for_testing(cap);
        vault::destroy_for_testing(v);
    }

    #[test]
    fun bound_fee_dust_rounds_to_zero() {
        let mut ctx = tx_context::dummy();
        let mut v = vault::create_for_testing(&mut ctx);
        vault::deposit(&mut v, coin::mint_for_testing<SUI>(1_000_000_000, &mut ctx));
        // 333 * 30 / 10_000 = 0 (truncated)
        let o = vault::withdraw(&mut v, 333, &mut ctx);
        assert!(coin::value(&o) == 333);
        coin::burn_for_testing(o);
        vault::destroy_for_testing(v);
    }

    #[test]
    fun bound_fee_first_nonzero() {
        let mut ctx = tx_context::dummy();
        let mut v = vault::create_for_testing(&mut ctx);
        vault::deposit(&mut v, coin::mint_for_testing<SUI>(1_000_000_000, &mut ctx));
        // ceil(10_000 / 30) = 334 → fee = 334 * 30 / 10_000 = 1
        let o = vault::withdraw(&mut v, 334, &mut ctx);
        assert!(coin::value(&o) == 333);
        coin::burn_for_testing(o);
        vault::destroy_for_testing(v);
    }
