#[test_only]
module suitears::fund_r2_tests {
    use suitears::fund;

    #[test]
    fun r2_empty_state() {
        let f = fund::empty();
        assert!(fund::shares(&f) == 0);
        assert!(fund::underlying(&f) == 0);
    }

    #[test]
    fun r2_first_add() {
        let mut f = fund::empty();
        let s = fund::add_underlying(&mut f, 5000, false);
        assert!(s == 5000);
        assert!(fund::underlying(&f) == 5000);
    }

    #[test]
    fun r2_proportional_second_add() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 2000, false);
        let s = fund::add_underlying(&mut f, 3000, false);
        assert!(s == 3000);
        assert!(fund::shares(&f) == 5000);
    }

    #[test]
    fun r2_profit_dilutes_new_shares() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 100, false);
        fund::add_profit(&mut f, 100);
        // underlying=200, shares=100. deposit 200 → shares = 200*100/200 = 100
        let s = fund::add_underlying(&mut f, 200, false);
        assert!(s == 100);
    }

    #[test]
    fun r2_sub_shares_full_drain() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 777, false);
        let u = fund::sub_shares(&mut f, 777, false);
        assert!(u == 777);
        assert!(fund::shares(&f) == 0);
        assert!(fund::underlying(&f) == 0);
    }

    #[test]
    fun r2_sub_shares_partial_with_profit() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 400, false);
        fund::add_profit(&mut f, 400);
        // underlying=800, shares=400. burn 200 → underlying = 200*800/400 = 400
        let u = fund::sub_shares(&mut f, 200, false);
        assert!(u == 400);
        assert!(fund::shares(&f) == 200);
        assert!(fund::underlying(&f) == 400);
    }

    #[test]
    fun r2_sub_underlying() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 600, false);
        let burned = fund::sub_underlying(&mut f, 300, false);
        assert!(burned == 300);
        assert!(fund::underlying(&f) == 300);
    }

    #[test]
    fun r2_to_shares_empty() {
        let f = fund::empty();
        assert!(fund::to_shares(&f, 999, false) == 999);
    }

    #[test]
    fun r2_to_underlying_empty() {
        let f = fund::empty();
        assert!(fund::to_underlying(&f, 999, false) == 999);
    }

    #[test]
    fun r2_to_shares_after_profit() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 500, false);
        fund::add_profit(&mut f, 500);
        // underlying=1000, shares=500. to_shares(100) = 100*500/1000 = 50
        assert!(fund::to_shares(&f, 100, false) == 50);
    }

    #[test]
    fun r2_to_underlying_after_profit() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 500, false);
        fund::add_profit(&mut f, 500);
        // underlying=1000, shares=500. to_underlying(50) = 50*1000/500 = 100
        assert!(fund::to_underlying(&f, 50, false) == 100);
    }

    #[test]
    fun r2_round_up_to_shares() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 3, false);
        fund::add_profit(&mut f, 1);
        // underlying=4, shares=3. to_shares(1, up) = ceil(3/4) = 1
        assert!(fund::to_shares(&f, 1, true) == 1);
        // round_down: 3/4 = 0
        assert!(fund::to_shares(&f, 1, false) == 0);
    }

    #[test]
    fun r2_round_up_to_underlying() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 3, false);
        fund::add_profit(&mut f, 1);
        // underlying=4, shares=3. to_underlying(1, up) = ceil(4/3) = 2
        assert!(fund::to_underlying(&f, 1, true) == 2);
        // round_down: 4/3 = 1
        assert!(fund::to_underlying(&f, 1, false) == 1);
    }

    #[test]
    fun r2_profit_no_shares_change() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 100, false);
        fund::add_profit(&mut f, 9999);
        assert!(fund::shares(&f) == 100);
        assert!(fund::underlying(&f) == 10099);
    }

    #[test]
    fun r2_add_one_unit() {
        let mut f = fund::empty();
        assert!(fund::add_underlying(&mut f, 1, false) == 1);
    }

    #[test]
    fun r2_large_values() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 1_000_000_000_000_000, false);
        fund::add_profit(&mut f, 1_000_000_000_000_000);
        // underlying=2e15, shares=1e15. deposit 1e15 → shares = 1e15*1e15/2e15 = 5e14
        let s = fund::add_underlying(&mut f, 1_000_000_000_000_000, false);
        assert!(s == 500_000_000_000_000);
    }

    #[test]
    fun r2_add_sub_roundtrip() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 10000, false);
        let u = fund::sub_shares(&mut f, 10000, false);
        assert!(u == 10000);
        assert!(fund::shares(&f) == 0);
        assert!(fund::underlying(&f) == 0);
    }

    #[test]
    fun r2_sub_underlying_round_up() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 3, false);
        fund::add_profit(&mut f, 1);
        // underlying=4, shares=3. sub_underlying(1, round_up):
        // shares_to_burn = to_shares(1, true) = ceil(3/4) = 1
        let burned = fund::sub_underlying(&mut f, 1, true);
        assert!(burned == 1);
    }

    #[test]
    fun r2_add_underlying_round_up() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 3, false);
        fund::add_profit(&mut f, 1);
        // underlying=4, shares=3. add_underlying(1, round_up):
        // shares = to_shares(1, true) = ceil(3/4) = 1
        let s = fund::add_underlying(&mut f, 1, true);
        assert!(s == 1);
    }
