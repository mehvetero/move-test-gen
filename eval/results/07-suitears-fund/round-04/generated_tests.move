// Generated by move-test-gen (scenario 07-suitears-fund, round 4, template: varied v1.1)
// Approach: enumerate every comparison in fund.move, then boundary test each
//
// Comparisons in fund.move:
//   L64: self.underlying == 0  → first-deposit branch
//   L65: round_up (bool)      → rounding direction
//   L81: rebase.shares == 0   → first-deposit branch for to_underlying
//   L82: round_up (bool)      → rounding direction

#[test_only]
module suitears::fund_varied_tests {
    use suitears::fund;

    // ── to_shares: underlying == 0 branch ──

    #[test]
    fun varied_to_shares_when_empty() {
        let f = fund::empty();
        assert!(fund::to_shares(&f, 42, false) == 42);
        assert!(fund::to_shares(&f, 42, true) == 42);
    }

    #[test]
    fun varied_to_shares_when_has_underlying() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 100, false);
        // underlying=100, shares=100. to_shares(50) = 50*100/100 = 50
        assert!(fund::to_shares(&f, 50, false) == 50);
    }

    // ── to_underlying: shares == 0 branch ──

    #[test]
    fun varied_to_underlying_when_no_shares() {
        let f = fund::empty();
        assert!(fund::to_underlying(&f, 42, false) == 42);
        assert!(fund::to_underlying(&f, 42, true) == 42);
    }

    #[test]
    fun varied_to_underlying_when_has_shares() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 100, false);
        assert!(fund::to_underlying(&f, 50, false) == 50);
    }

    // ── rounding direction exhaustive ──

    #[test]
    fun varied_round_down_truncates() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 10, false);
        fund::add_profit(&mut f, 3);
        // underlying=13, shares=10. to_shares(1, down) = floor(10/13) = 0
        assert!(fund::to_shares(&f, 1, false) == 0);
        // to_underlying(1, down) = floor(13/10) = 1
        assert!(fund::to_underlying(&f, 1, false) == 1);
    }

    #[test]
    fun varied_round_up_ceils() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 10, false);
        fund::add_profit(&mut f, 3);
        // underlying=13, shares=10. to_shares(1, up) = ceil(10/13) = 1
        assert!(fund::to_shares(&f, 1, true) == 1);
        // to_underlying(1, up) = ceil(13/10) = 2
        assert!(fund::to_underlying(&f, 1, true) == 2);
    }

    // ── add_underlying round_up vs round_down ──

    #[test]
    fun varied_add_underlying_rounding() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 7, false);
        fund::add_profit(&mut f, 3);
        // underlying=10, shares=7
        // add 1 round_down: shares = floor(1*7/10) = 0
        let mut f2 = f;
        assert!(fund::add_underlying(&mut f2, 1, false) == 0);
        // add 1 round_up: shares = ceil(1*7/10) = 1
        assert!(fund::add_underlying(&mut f, 1, true) == 1);
    }

    // ── sub_shares round_up vs round_down ──

    #[test]
    fun varied_sub_shares_rounding() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 7, false);
        fund::add_profit(&mut f, 3);
        // underlying=10, shares=7
        let mut f2 = f;
        // sub 1 share round_down: underlying = floor(1*10/7) = 1
        assert!(fund::sub_shares(&mut f2, 1, false) == 1);
        // sub 1 share round_up: underlying = ceil(1*10/7) = 2
        assert!(fund::sub_shares(&mut f, 1, true) == 2);
    }

    // ── sub_underlying round_up vs round_down ──

    #[test]
    fun varied_sub_underlying_rounding() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 7, false);
        fund::add_profit(&mut f, 3);
        let mut f2 = f;
        // sub 1 underlying round_down: shares = floor(1*7/10) = 0
        assert!(fund::sub_underlying(&mut f2, 1, false) == 0);
        // sub 1 underlying round_up: shares = ceil(1*7/10) = 1
        assert!(fund::sub_underlying(&mut f, 1, true) == 1);
    }

    // ── add_profit effect on ratios ──

    #[test]
    fun varied_profit_changes_ratio() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 100, false);
        // before profit: 1 share = 1 underlying
        assert!(fund::to_underlying(&f, 1, false) == 1);
        fund::add_profit(&mut f, 100);
        // after profit: 1 share = 2 underlying
        assert!(fund::to_underlying(&f, 1, false) == 2);
    }

    // ── zero input on populated fund ──

    #[test]
    fun varied_to_shares_zero() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 100, false);
        assert!(fund::to_shares(&f, 0, false) == 0);
        assert!(fund::to_shares(&f, 0, true) == 0);
    }

    #[test]
    fun varied_to_underlying_zero() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 100, false);
        assert!(fund::to_underlying(&f, 0, false) == 0);
        assert!(fund::to_underlying(&f, 0, true) == 0);
    }
}
