// Generated by move-test-gen (scenario 07-suitears-fund, round 1, template: main v1.1)
// Target: suitears::fund (real protocol — Interest Protocol SuiTears)
// Pure arithmetic module — no asserts/aborts. Mutation is the only verification layer.

#[test_only]
module suitears::fund_tests {
    use suitears::fund;

    // ── empty fund state ──

    #[test]
    fun t_empty_fund() {
        let f = fund::empty();
        assert!(fund::shares(&f) == 0);
        assert!(fund::underlying(&f) == 0);
    }

    // ── first deposit: 1:1 ratio ──

    #[test]
    fun t_first_deposit_1to1() {
        let mut f = fund::empty();
        let shares = fund::add_underlying(&mut f, 1000, false);
        assert!(shares == 1000);
        assert!(fund::shares(&f) == 1000);
        assert!(fund::underlying(&f) == 1000);
    }

    // ── second deposit proportional ──

    #[test]
    fun t_second_deposit_proportional() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 1000, false);
        let s2 = fund::add_underlying(&mut f, 500, false);
        assert!(s2 == 500);
        assert!(fund::underlying(&f) == 1500);
        assert!(fund::shares(&f) == 1500);
    }

    // ── deposit after profit: fewer shares ──

    #[test]
    fun t_deposit_after_profit() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 1000, false);
        fund::add_profit(&mut f, 1000);
        // underlying=2000, shares=1000. New deposit of 1000:
        // shares = 1000 * 1000 / 2000 = 500
        let s2 = fund::add_underlying(&mut f, 1000, false);
        assert!(s2 == 500);
        assert!(fund::underlying(&f) == 3000);
        assert!(fund::shares(&f) == 1500);
    }

    // ── withdraw returns correct underlying ──

    #[test]
    fun t_sub_shares_returns_underlying() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 1000, false);
        let underlying = fund::sub_shares(&mut f, 1000, false);
        assert!(underlying == 1000);
        assert!(fund::shares(&f) == 0);
        assert!(fund::underlying(&f) == 0);
    }

    // ── withdraw after profit: more underlying per share ──

    #[test]
    fun t_sub_shares_after_profit() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 1000, false);
        fund::add_profit(&mut f, 500);
        // underlying=1500, shares=1000. Burn 500 shares:
        // underlying = 500 * 1500 / 1000 = 750
        let underlying = fund::sub_shares(&mut f, 500, false);
        assert!(underlying == 750);
        assert!(fund::shares(&f) == 500);
        assert!(fund::underlying(&f) == 750);
    }

    // ── to_shares view function ──

    #[test]
    fun t_to_shares_empty() {
        let f = fund::empty();
        // when underlying==0, returns input directly
        assert!(fund::to_shares(&f, 1000, false) == 1000);
    }

    #[test]
    fun t_to_shares_with_state() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 2000, false);
        fund::add_profit(&mut f, 2000);
        // underlying=4000, shares=2000. to_shares(1000) = 1000 * 2000 / 4000 = 500
        assert!(fund::to_shares(&f, 1000, false) == 500);
    }

    // ── to_underlying view function ──

    #[test]
    fun t_to_underlying_empty() {
        let f = fund::empty();
        // when shares==0, returns input directly
        assert!(fund::to_underlying(&f, 1000, false) == 1000);
    }

    #[test]
    fun t_to_underlying_with_state() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 2000, false);
        fund::add_profit(&mut f, 2000);
        // underlying=4000, shares=2000. to_underlying(500) = 500 * 4000 / 2000 = 1000
        assert!(fund::to_underlying(&f, 500, false) == 1000);
    }

    // ── rounding: round_up vs round_down ──

    #[test]
    fun t_to_shares_round_down() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 1000, false);
        fund::add_profit(&mut f, 1);
        // underlying=1001, shares=1000. to_shares(1, round_down) = 1 * 1000 / 1001 = 0
        assert!(fund::to_shares(&f, 1, false) == 0);
    }

    #[test]
    fun t_to_shares_round_up() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 1000, false);
        fund::add_profit(&mut f, 1);
        // underlying=1001, shares=1000. to_shares(1, round_up) = ceil(1000/1001) = 1
        assert!(fund::to_shares(&f, 1, true) == 1);
    }

    #[test]
    fun t_to_underlying_round_down() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 1000, false);
        fund::add_profit(&mut f, 1);
        // underlying=1001, shares=1000. to_underlying(1, round_down) = 1 * 1001 / 1000 = 1
        assert!(fund::to_underlying(&f, 1, false) == 1);
    }

    #[test]
    fun t_to_underlying_round_up() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 1000, false);
        fund::add_profit(&mut f, 1);
        // underlying=1001, shares=1000. to_underlying(1, round_up) = ceil(1001/1000) = 2
        assert!(fund::to_underlying(&f, 1, true) == 2);
    }

    // ── sub_underlying burns correct shares ──

    #[test]
    fun t_sub_underlying() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 1000, false);
        let burned = fund::sub_underlying(&mut f, 500, false);
        assert!(burned == 500);
        assert!(fund::shares(&f) == 500);
        assert!(fund::underlying(&f) == 500);
    }

    // ── add_profit doesn't change shares ──

    #[test]
    fun t_add_profit_shares_unchanged() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 1000, false);
        let shares_before = fund::shares(&f);
        fund::add_profit(&mut f, 5000);
        assert!(fund::shares(&f) == shares_before);
        assert!(fund::underlying(&f) == 6000);
    }

    // ── boundary: deposit 1 unit ──

    #[test]
    fun t_deposit_one_unit() {
        let mut f = fund::empty();
        let shares = fund::add_underlying(&mut f, 1, false);
        assert!(shares == 1);
    }

    // ── boundary: large values ──

    #[test]
    fun t_large_deposit() {
        let mut f = fund::empty();
        let shares = fund::add_underlying(&mut f, 1_000_000_000_000, false);
        assert!(shares == 1_000_000_000_000);
        assert!(fund::underlying(&f) == 1_000_000_000_000);
    }
}
