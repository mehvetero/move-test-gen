#[test_only]
module suitears::fund_r3_tests {
    use suitears::fund;

    #[test]
    fun r3_empty() {
        let f = fund::empty();
        assert!(fund::shares(&f) == 0);
        assert!(fund::underlying(&f) == 0);
    }

    #[test]
    fun r3_first_deposit() {
        let mut f = fund::empty();
        assert!(fund::add_underlying(&mut f, 12345, false) == 12345);
    }

    #[test]
    fun r3_deposit_after_double_profit() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 100, false);
        fund::add_profit(&mut f, 200);
        // underlying=300, shares=100. deposit 300 → shares = 300*100/300 = 100
        assert!(fund::add_underlying(&mut f, 300, false) == 100);
    }

    #[test]
    fun r3_sub_shares_round_up() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 3, false);
        fund::add_profit(&mut f, 1);
        // underlying=4, shares=3. sub_shares(1, round_up):
        // underlying = ceil(1 * 4 / 3) = 2
        let u = fund::sub_shares(&mut f, 1, true);
        assert!(u == 2);
        assert!(fund::underlying(&f) == 2);
        assert!(fund::shares(&f) == 2);
    }

    #[test]
    fun r3_sub_shares_round_down() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 3, false);
        fund::add_profit(&mut f, 1);
        // underlying=4, shares=3. sub_shares(1, round_down):
        // underlying = floor(1 * 4 / 3) = 1
        let u = fund::sub_shares(&mut f, 1, false);
        assert!(u == 1);
        assert!(fund::underlying(&f) == 3);
        assert!(fund::shares(&f) == 2);
    }

    #[test]
    fun r3_to_shares_exact_division() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 1000, false);
        fund::add_profit(&mut f, 1000);
        // underlying=2000, shares=1000. 500 → 500*1000/2000 = 250 exact
        assert!(fund::to_shares(&f, 500, false) == 250);
        assert!(fund::to_shares(&f, 500, true) == 250);
    }

    #[test]
    fun r3_to_underlying_exact_division() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 1000, false);
        fund::add_profit(&mut f, 1000);
        // underlying=2000, shares=1000. 250 → 250*2000/1000 = 500 exact
        assert!(fund::to_underlying(&f, 250, false) == 500);
        assert!(fund::to_underlying(&f, 250, true) == 500);
    }

    #[test]
    fun r3_multiple_profits() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 100, false);
        fund::add_profit(&mut f, 50);
        fund::add_profit(&mut f, 50);
        assert!(fund::underlying(&f) == 200);
        assert!(fund::shares(&f) == 100);
    }

    #[test]
    fun r3_deposit_withdraw_cycle() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 1000, false);
        fund::add_profit(&mut f, 500);
        // underlying=1500, shares=1000
        let u = fund::sub_shares(&mut f, 500, false);
        // 500 * 1500 / 1000 = 750
        assert!(u == 750);
        // remaining: underlying=750, shares=500
        let s = fund::add_underlying(&mut f, 750, false);
        // 750 * 500 / 750 = 500
        assert!(s == 500);
        assert!(fund::shares(&f) == 1000);
        assert!(fund::underlying(&f) == 1500);
    }

    #[test]
    fun r3_sub_underlying_round_down() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 7, false);
        fund::add_profit(&mut f, 3);
        // underlying=10, shares=7. sub_underlying(3, down):
        // shares = floor(3 * 7 / 10) = 2
        let burned = fund::sub_underlying(&mut f, 3, false);
        assert!(burned == 2);
    }

    #[test]
    fun r3_sub_underlying_round_up() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 7, false);
        fund::add_profit(&mut f, 3);
        // underlying=10, shares=7. sub_underlying(3, up):
        // shares = ceil(3 * 7 / 10) = 3
        let burned = fund::sub_underlying(&mut f, 3, true);
        assert!(burned == 3);
    }

    #[test]
    fun r3_zero_deposit() {
        let mut f = fund::empty();
        let s = fund::add_underlying(&mut f, 0, false);
        assert!(s == 0);
        assert!(fund::shares(&f) == 0);
    }

    #[test]
    fun r3_zero_withdraw() {
        let mut f = fund::empty();
        fund::add_underlying(&mut f, 100, false);
        let u = fund::sub_shares(&mut f, 0, false);
        assert!(u == 0);
        assert!(fund::shares(&f) == 100);
    }
}
