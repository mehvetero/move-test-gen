    #[test]
    fun test_flash_borrow_repay_roundtrip() {
        let mut ctx = tx_context::dummy();
        let mut v = vault::create_for_testing(&mut ctx);
        let c = coin::mint_for_testing<SUI>(ONE_SUI, &mut ctx);
        vault::deposit(&mut v, c);
        let bal_before = vault::balance(&v);
        let (mut borrowed, receipt) = vault::flash_borrow(&mut v, ONE_SUI / 2, &mut ctx);
        // fee = 500_000_000 * 30 / 10000 = 1_500_000
        let fee = coin::mint_for_testing<SUI>(1_500_000, &mut ctx);
        borrowed.join(fee);
        vault::flash_repay(&mut v, borrowed, receipt);
        assert!(vault::balance(&v) == bal_before + 1_500_000);
        vault::destroy_for_testing(v);
    }

